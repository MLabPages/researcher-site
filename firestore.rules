rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isModerator() {
      return request.auth != null
        && exists(/databases/$(database)/documents/moderators/$(request.auth.uid));
    }

    match /toolStats/{toolId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['opens'])
        && request.resource.data.opens == 1;
      allow update: if request.resource.data.keys().hasOnly(['opens'])
        && request.resource.data.opens == resource.data.opens + 1;
      allow delete: if false;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'toolId', 'text', 'uid', 'displayName', 'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.toolId is string
        && request.resource.data.toolId.size() <= 80
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.createdAt == request.time;
      allow update: if false;
      allow delete: if request.auth != null
        && (resource.data.uid == request.auth.uid || isModerator());
    }

    match /moderators/{moderatorId} {
      allow read: if request.auth != null
        && request.auth.uid == moderatorId;
      allow write: if false;
    }
  }
}
